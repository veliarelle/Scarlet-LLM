{
  "name": "scarlet-llm",
  "version": "1.0.8",
  "description": "Scarlet LLM - local cross-platform frontend for LLMs",
  "type": "module",
  "scripts": {
    "dev": "vite dev --force",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:build:appimage": "VERSION=$npm_package_version NO_STRIP=1 tauri build --bundles appimage",
    "tauri:bundle:appimage": "VERSION=$npm_package_version NO_STRIP=1 tauri bundle --bundles appimage"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
