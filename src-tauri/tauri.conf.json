{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scarlet LLM",
  "version": "1.0.6",
  "identifier": "dev.scarlet.llm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Scarlet LLM",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 480,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI --ignore-gpu-blocklist --enable-gpu-rasterization --enable-zero-copy"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: http:; font-src 'self' data:; connect-src 'self' https: http: ws: wss:; media-src 'self' data: blob:; object-src 'none'; base-uri 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "versionCode": 1000006
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
