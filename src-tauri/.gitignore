# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Android generated build output and local signing secrets
/gen/android/.gradle/
/gen/android/**/build/
/gen/android/local.properties
/gen/android/keystore.properties
/gen/android/key.properties

# Local release/signing artifacts
*.apk
*.aab
*.apks
*.idsig
*.keystore
*.jks
